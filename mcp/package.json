{
  "name": "sendblue-browser-mcp",
  "version": "0.2.3",
  "mcpName": "io.github.sendblue-api/sendblue-browser-mcp",
  "description": "MCP server wrapping the sendblue-browser-use daemon. Exposes navigate, screenshot, script, session lifecycle, and CDP attach as MCP tools so any MCP client (Claude Desktop, Codex, Cursor, Antigravity, Cline, Windsurf) can drive a stealth-patched Chromium.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sendblue-browser-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "browser",
    "browser-automation",
    "chromium",
    "patchright",
    "stealth",
    "playwright",
    "cdp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sendblue-api/sendblue-browser-use.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/sendblue-api/sendblue-browser-use/tree/main/mcp",
  "publishConfig": {
    "access": "public"
  }
}
