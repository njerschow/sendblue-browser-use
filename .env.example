# sendblue-browser-use — environment

# REQUIRED: bearer token for the HTTP API. Generate with: openssl rand -hex 32
BROWSER_USE_API_KEY=

# Optional. Defaults shown.
# PORT=8787
# BIND=127.0.0.1            # set to 0.0.0.0 to allow LAN access (use with caution)
# CDP_PORT=9222             # remote-debugging-port for the headed Chromium
# CDP_BIND=127.0.0.1        # bind for Chromium's CDP socket. Anyone who can reach
#                           # this port gets full RCE — keep on loopback.
# DATA_DIR=~/.sendblue-browser-use
# DEFAULT_HEADLESS=false    # true|false|new
# IDLE_SESSION_MINUTES=120  # auto-evict sessions idle longer than this. 0 to disable.
# MAX_CONSOLE_BUFFER=500    # per-session console-message ring buffer

# Default Playwright/patchright args (comma-separated). Leave empty for defaults.
# CHROMIUM_ARGS=
